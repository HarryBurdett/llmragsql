{
  "type_id": "bank_transfer",
  "label": "Bank Transfer",
  "category": "cashbook",
  "import_method": "import_bank_transfer",
  "description": "Transfer between bank accounts. Creates: 2x aentry (opposite signs), 2x atran (at_type=8, at_account=counterpart), 2x ntran (opposite signs), 2x anoml (ax_source=A, shared ax_unique). Updates: both nbank.nk_curbal, both nacnt, atype.ay_entry.",
  "user_fields": [
    {"name": "amount_pounds", "label": "Amount (£)", "required": true, "field_type": "decimal"},
    {"name": "post_date", "label": "Date", "required": true, "field_type": "date"},
    {"name": "reference", "label": "Reference", "required": false, "field_type": "string", "max_length": 30}
  ],
  "default_fields": [
    {"name": "source_bank", "label": "From Bank", "required": true, "field_type": "string", "source": "template", "lookup_table": "nbank"},
    {"name": "dest_bank", "label": "To Bank", "required": true, "field_type": "string", "source": "template", "lookup_table": "nbank"},
    {"name": "cbtype", "label": "Cashbook Type Code", "required": false, "field_type": "string", "source": "template"},
    {"name": "input_by", "label": "Input By", "required": false, "field_type": "string", "default": "IMPORT"}
  ],
  "auto_fields": ["entry_number", "journal_number", "unique_id", "row_id"],
  "tables_written": ["aentry", "atran", "ntran", "anoml"],
  "tables_updated": ["nbank", "nacnt", "nhist", "atype"],
  "duplicate_detection": {"match_on": ["amount_pounds", "post_date"], "date_range_days": 7},
  "validate_only_supported": true
}
