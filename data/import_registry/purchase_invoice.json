{
  "type_id": "purchase_invoice",
  "label": "Purchase Invoice",
  "category": "purchase_ledger",
  "import_method": "import_purchase_invoice_posting",
  "description": "Purchase invoice posting. Creates: ptran (pt_trtype=I), pnoml, ntran (creditors control CR, expense nominal DR), nacnt updates. Optional VAT creates zvtran + nvat. Updates: pname.pn_currbal.",
  "user_fields": [
    {"name": "supplier_account", "label": "Supplier Code", "required": true, "field_type": "string", "lookup_table": "pname"},
    {"name": "invoice_number", "label": "Invoice Number", "required": true, "field_type": "string", "max_length": 30},
    {"name": "net_amount", "label": "Net Amount (£)", "required": true, "field_type": "decimal"},
    {"name": "vat_amount", "label": "VAT Amount (£)", "required": false, "field_type": "decimal"},
    {"name": "post_date", "label": "Date", "required": true, "field_type": "date"},
    {"name": "due_date", "label": "Due Date", "required": false, "field_type": "date"},
    {"name": "description", "label": "Description", "required": false, "field_type": "string"}
  ],
  "default_fields": [
    {"name": "expense_nominal", "label": "Expense Nominal Code", "required": true, "field_type": "string", "source": "template", "lookup_table": "nacnt"},
    {"name": "vat_code", "label": "VAT Code", "required": "conditional", "field_type": "string", "condition": "Required if vat_amount > 0"},
    {"name": "vat_nominal", "label": "VAT Nominal Code", "required": "conditional", "field_type": "string", "source": "template", "lookup_table": "nacnt", "condition": "Required if vat_amount > 0"},
    {"name": "department_code", "label": "Department", "required": "conditional", "field_type": "string", "condition": "Check nacnt analysis settings for target nominal account"},
    {"name": "project_code", "label": "Project", "required": "conditional", "field_type": "string", "condition": "Check nacnt analysis settings for target nominal account"},
    {"name": "input_by", "label": "Input By", "required": false, "field_type": "string", "default": "IMPORT"}
  ],
  "auto_fields": ["journal_number", "unique_id", "row_id", "control_account"],
  "tables_written": ["ptran", "pnoml", "ntran"],
  "tables_written_conditional": ["zvtran", "nvat"],
  "tables_updated": ["pname", "nacnt", "nhist", "nparm"],
  "duplicate_detection": {"match_on": ["supplier_account", "invoice_number"], "date_range_days": 30},
  "validate_only_supported": true
}
